# ============================================================================
# Configuration du déploiement serveur Afriland (deploy/server/deploy.sh)
# Copiez ce fichier en `.env` dans deploy/server/ et ajustez si besoin.
#   cp deploy/server/.env.example deploy/server/.env
# ============================================================================

# --- Ports publiés sur l'HÔTE (tous dans la plage 6000-7000) ---
UNION_PORT=6080       # Portail unifié (HTTP, point d'entrée navigateur)
UNION_SSL_PORT=6443   # Portail unifié en HTTPS (requis pour la caméra/selfie)
PROMOTE_PORT=6390     # Backend promote (Spring Boot)  -> conteneur :8390
DIASPORA_PORT=6002    # Backend diaspora (FastAPI)      -> conteneur :8010

# --- Dépôts GitHub (les 3 briques) ---
UNION_REPO=https://github.com/Efraim0601/union-portal.git
PROMOTE_REPO=https://github.com/Efraim0601/promoteApp.git
DIASPORA_REPO=https://github.com/Kholia-1/diaspora-onboarding.git

# Branche à déployer — chaque dépôt a SA branche de travail :
GIT_BRANCH=master                          # union-portal
PROMOTE_BRANCH=feat/refonte-ux-parcours    # promoteApp (backend actuel)
DIASPORA_BRANCH=develop                    # diaspora-onboarding (backend actuel)

# --- Dossier de travail sur le serveur (les 3 dépôts y sont clonés) ---
DEPLOY_DIR=/opt/afriland
