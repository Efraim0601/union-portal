# ============================================================================
# MANIFESTE DES COMPOSANTS DE LA SOLUTION UNION
#
# Source unique de vérité du déploiement : chaque composant (dépôt, branche,
# chemin sur le serveur, port hôte, service compose) est décrit ICI, et
# `deploy/server/deploy.sh` s'en sert pour TOUT déployer.
#
# Pour ajouter/modifier un composant : éditez ce fichier, pas le script.
# Pour surcharger sans toucher au dépôt : créez `deploy/server/.env`
# (mêmes variables ; il est chargé APRÈS ce fichier et gagne).
# ============================================================================

# Ordre de déploiement : les backends d'abord, le portail en dernier (il les
# proxifie et sa vérification de santé dépend d'eux).
COMPONENTS="${COMPONENTS:-hub promote diaspora union}"

# ---------------------------------------------------------------------------
# Payment Hub — encaissement MoMo/carte, mutualisé avec les autres applications
# ⚠ Le compte marchand est GLOBAL par provider : le redéployer impacte aussi
#   les autres applications branchées sur le Hub.
# ---------------------------------------------------------------------------
HUB_DIR="${HUB_DIR:-/opt/payment-hub}"
HUB_REPO="${HUB_REPO:-git@github-firstscol:Efraim0601/payment-hub.git}"
HUB_BRANCH="${HUB_BRANCH:-main}"
HUB_COMPOSE="${HUB_COMPOSE:-docker-compose.prod.yml}"
HUB_SERVICE="${HUB_SERVICE:-payment-hub}"
HUB_CONTAINER="${HUB_CONTAINER:-payment-hub-payment-hub-1}"
HUB_HEALTH="${HUB_HEALTH:-http://127.0.0.1:8090/actuator/health}"

# ---------------------------------------------------------------------------
# Backend promote — Spring Boot + Postgres + MinIO (staff, ventes, stats)
# Le port hôte n'est PAS publié par le compose du dépôt : deploy.sh génère un
# override (.ports.override.yml) pour exposer PROMOTE_PORT -> 8390.
# ---------------------------------------------------------------------------
PROMOTE_DIR="${PROMOTE_DIR:-/opt/promoteApp}"
PROMOTE_REPO="${PROMOTE_REPO:-git@github-promoteapp:Efraim0601/promoteApp.git}"
PROMOTE_BRANCH="${PROMOTE_BRANCH:-feat/refonte-ux-parcours}"
PROMOTE_COMPOSE="${PROMOTE_COMPOSE:-docker-compose.yml}"
PROMOTE_SERVICE="${PROMOTE_SERVICE:-backend}"
PROMOTE_CONTAINER="${PROMOTE_CONTAINER:-promoteapp-backend-1}"
PROMOTE_PORT="${PROMOTE_PORT:-6390}"          # hôte -> conteneur 8390
PROMOTE_TARGET_PORT="${PROMOTE_TARGET_PORT:-8390}"
PROMOTE_HEALTH="${PROMOTE_HEALTH:-http://localhost:${PROMOTE_PORT}/api/products}"

# ---------------------------------------------------------------------------
# Backend diaspora — FastAPI (onboarding, OCR CNI)
# ⚠ Force HTTPS quand X-Forwarded-Proto=http : son API n'est joignable via le
#   portail qu'en HTTPS (UNION_SSL_PORT). Voir README §Accès.
# ---------------------------------------------------------------------------
DIASPORA_DIR="${DIASPORA_DIR:-/opt/afriland/diaspora-onboarding}"
DIASPORA_REPO="${DIASPORA_REPO:-https://github.com/Kholia-1/diaspora-onboarding.git}"
DIASPORA_BRANCH="${DIASPORA_BRANCH:-develop}"
DIASPORA_COMPOSE="${DIASPORA_COMPOSE:-docker-compose.yml}"
DIASPORA_SERVICE="${DIASPORA_SERVICE:-diaspora-onboarding}"
DIASPORA_CONTAINER="${DIASPORA_CONTAINER:-diaspora-onboarding}"
DIASPORA_PORT="${DIASPORA_PORT:-6002}"        # hôte -> conteneur 8010
DIASPORA_TARGET_PORT="${DIASPORA_TARGET_PORT:-8010}"
DIASPORA_HEALTH="${DIASPORA_HEALTH:-http://localhost:${DIASPORA_PORT}/health}"

# ---------------------------------------------------------------------------
# Portail union — Angular (shell + remotes promote/diaspora) derrière nginx.
# Sert les 3 fronts sur UNE origine et proxifie les backends :
#   /promote-api/*  -> promote   |   /api/*  -> diaspora
# ---------------------------------------------------------------------------
UNION_DIR="${UNION_DIR:-/opt/union-portal}"
UNION_REPO="${UNION_REPO:-git@github-promoteapp:Efraim0601/union-portal.git}"
UNION_BRANCH="${UNION_BRANCH:-master}"
UNION_COMPOSE="${UNION_COMPOSE:-docker-compose.yml}"
UNION_SERVICE="${UNION_SERVICE:-union}"
UNION_CONTAINER="${UNION_CONTAINER:-afriland-union}"
UNION_PORT="${UNION_PORT:-6080}"              # portail HTTP
UNION_SSL_PORT="${UNION_SSL_PORT:-6443}"      # portail HTTPS (caméra/selfie + API diaspora)
UNION_HEALTH="${UNION_HEALTH:-http://localhost:${UNION_PORT}/}"

# Upstreams injectés dans le nginx du portail (backends sur l'hôte).
PROMOTE_UPSTREAM="${PROMOTE_UPSTREAM:-host.docker.internal:${PROMOTE_PORT}}"
DIASPORA_UPSTREAM="${DIASPORA_UPSTREAM:-host.docker.internal:${DIASPORA_PORT}}"
