{
  "name": "union-portal",
  "version": "0.0.0",
  "description": "Monorepo Angular CLI — Afriland Union (shell + promote + diaspora + libs partagées). Architecture host/remotes via Native Federation, design-system uniforme aligné sur portal-client-firstpay.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve shell",
    "serve:shell": "ng serve shell",
    "serve:promote": "ng serve promote",
    "serve:diaspora": "ng serve diaspora",
    "serve:all": "bash start-all.sh",
    "build": "ng build",
    "build:all": "ng build shell && ng build promote && ng build diaspora"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@softarc/native-federation-node": "^3.3.4",
    "es-module-shims": "^1.5.12",
    "gsap": "^3.12.5",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.13.6",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "21.2.5",
