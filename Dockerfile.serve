# Image "serve-only" : sert des dist DÉJÀ construits (npm run build:all avant).
# Utile quand on build hors Docker (CI) puis on empaquette. Déploiement rapide,
# sans réinstaller les deps dans l'image.
#   npm run build:all
#   docker build -f Dockerfile.serve -t afriland-union .
#   docker run -p 8080:80 afriland-union
FROM nginx:1.27-alpine
# Upstreams backend paramétrables (envsubst au démarrage) — défauts = hôte.
ENV PROMOTE_UPSTREAM=host.docker.internal:8390
ENV DIASPORA_UPSTREAM=host.docker.internal:10002
COPY deploy/nginx.conf /etc/nginx/templates/default.conf.template
COPY dist/shell/browser/    /usr/share/nginx/html/
COPY dist/promote/browser/  /usr/share/nginx/html/remotes/promote/
COPY dist/diaspora/browser/ /usr/share/nginx/html/remotes/diaspora/
COPY deploy/federation.manifest.prod.json /usr/share/nginx/html/federation.manifest.json
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
