# Copiez ce fichier en .env (ignoré par git) puis renseignez vos identifiants Callbell.
PORT=10002

# Tableau de bord Callbell > Paramètres > API
CALLBELL_API_KEY=

# UUID du channel WhatsApp Callbell à utiliser pour l'envoi
CALLBELL_CHANNEL_UUID=

# Identifiant du canal source Callbell (laisser tel quel sauf indication contraire de Callbell)
CALLBELL_FROM=whatsapp
