# Copiez ce fichier en .env (ignoré par git) puis renseignez vos identifiants Callbell.
PORT=10002

# PostgreSQL (obligatoire) — ex. le service `postgres` de deploy/test/docker-compose.yml.
# Pour un dev local SANS Docker : `node loadtest/pg-dev.mjs` lance un Postgres embarqué
# et affiche le DATABASE_URL à utiliser.
DATABASE_URL=postgres://diaspora:diaspora@localhost:5432/diaspora

# Connexions Postgres max PAR worker (le cluster lance un worker par cœur, cf. server.js).
PG_POOL_MAX=10

# Nombre de workers du cluster (défaut : nombre de cœurs ; 1 = mono-process pour déboguer)
#CLUSTER_WORKERS=1

# Tableau de bord Callbell > Paramètres > API
CALLBELL_API_KEY=

# UUID du channel WhatsApp Callbell à utiliser pour l'envoi
CALLBELL_CHANNEL_UUID=

# Identifiant du canal source Callbell (laisser tel quel sauf indication contraire de Callbell)
CALLBELL_FROM=whatsapp
